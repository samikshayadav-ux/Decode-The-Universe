# Frontend Environment Variables

# Backend API URL
VITE_API_URL=http://localhost:5000
# Production: VITE_API_URL=https://your-backend-domain.com

# Instructions:
# 1. Copy this file to .env
# 2. Update the values according to your environment
# 3. For development, use http://localhost:5000 for VITE_API_URL
# 4. For production, replace with your backend server URL
# 5. Do NOT commit the .env file to version control
